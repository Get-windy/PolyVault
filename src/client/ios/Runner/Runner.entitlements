<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Keychain访问权限 -->
    <key>keychain-access-groups</key>
    <array>
        <string>$(AppIdentifierPrefix)com.polyvault.client</string>
    </array>
    
    <!-- 安全Enclave访问 -->
    <key>com.apple.developer.secure-enclave-access</key>
    <true/>
</dict>
</plist>
